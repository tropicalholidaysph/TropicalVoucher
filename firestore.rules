rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Standard rules for Tropical Ledger
    // Allowing full access to authenticated users for the spreadsheet system
    match /vouchers/{voucherId} {
      allow read, write: if request.auth != null;
    }
    match /ledgers/{ledgerId} {
      allow read, write: if request.auth != null;
    }
    // Fallback wildcard rule
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}