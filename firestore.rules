rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Universal access rule for authenticated users.
    // This allows anonymous sessions (sign-in provider 'custom') to manage the ledger.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Deployment trigger version: v7.0.0 - Standard recursive authenticated access
  }
}