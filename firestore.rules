rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Explicitly allow access to the vouchers collection and documents
    match /vouchers/{voucherId} {
      allow read, write: if request.auth != null;
    }

    // Explicitly allow access to the ledgers collection and documents
    match /ledgers/{ledgerId} {
      allow read, write: if request.auth != null;
    }

    // Universal fallback for any authenticated user (including anonymous)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Deployment trigger version: v3.0.0 - Critical rule propagation for anonymous ledger access
  }
}