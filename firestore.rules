rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Explicitly allow all authenticated users (including anonymous)
    // full access to the vouchers and ledgers collections.
    // This resolves permission errors for the secure spreadsheet dashboard.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Deployment trigger version: v2.0.5
  }
}