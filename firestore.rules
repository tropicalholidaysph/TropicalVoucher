rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Broad rule to allow all authenticated users (including anonymous) full access.
    // This resolves specificity conflicts that can cause "list" operations to fail.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Deployment trigger version: v4.0.0 - Simplified recursive match for robust permission handling
  }
}